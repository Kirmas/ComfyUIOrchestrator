# Copy to backend/.env and fill in real values.

# Shared bearer token the frontend/API clients must send (single local user, no login flow)
API_TOKEN=change-me-to-a-long-random-string

# Postgres (native `postgresql` service on Debian) -- recommended.
DATABASE_URL=postgresql+asyncpg://orchestrator:orchestrator@localhost:5432/orchestrator
# Fallback if Postgres isn't installed on this machine: a plain SQLite file,
# no server/service needed. Fine for a single local user with modest load.
# DATABASE_URL=sqlite+aiosqlite:///./orchestrator.db

# Where generated assets (images, 3D meshes, uploads) are stored on disk.
# Relative paths resolve against backend/'s working directory.
MEDIA_DIR=./media

# Absolute path to the built frontend (frontend/dist after `npm run build`)
FRONTEND_DIST_DIR=/opt/comfy-orchestrator/frontend/dist

# Limits
MAX_VARIANTS_PER_NODE=8
JOB_TIMEOUT_SECONDS=600
MAX_RETRIES=2
HEARTBEAT_INTERVAL_SECONDS=15
DISPATCH_POLL_INTERVAL_SECONDS=3
WORKER_CONCURRENCY=4

CORS_ORIGINS=["http://localhost:5173"]
